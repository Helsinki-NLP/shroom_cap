    "import pandas as pd\n",
    "from sklearn.metrics import precision_score, recall_score, accuracy_score\n",
    "\n",
    "def compute_metrics(df):\n",
    "    \"\"\"\n",
    "    Compute language-wise and overall precision, recall, accuracy\n",
    "    using hallucinated (predicted) vs factual_mistake (ground truth).\n",
    "    \"\"\"\n",
    "\n",
    "    metrics = {}\n",
    "\n",
    "    # Ensure we have language codes\n",
    "    if \"language\" not in df.columns:\n",
    "        df[\"language\"] = df[\"index\"].str[:2]\n",
    "\n",
    "    languages = df[\"language\"].unique()\n",
    "\n",
    "    for lang in languages:\n",
    "        lang_df = df[df[\"language\"] == lang]\n",
    "\n",
    "        y_true = lang_df[\"factual_mistake\"].astype(str)\n",
    "        y_pred = lang_df[\"hallucinated\"].astype(str)\n",
    "\n",
    "        precision = precision_score(y_true, y_pred, pos_label=\"y\", zero_division=0)\n",
    "        recall = recall_score(y_true, y_pred, pos_label=\"y\", zero_division=0)\n",
    "        accuracy = accuracy_score(y_true, y_pred)\n",
    "\n",
    "        metrics[lang] = {\n",
    "            \"precision\": precision,\n",
    "            \"recall\": recall,\n",
    "            \"accuracy\": accuracy,\n",
    "            \"support\": len(lang_df)\n",
    "        }\n",
    "\n",
    "    # Overall metrics\n",
    "    y_true_all = df[\"factual_mistake\"].astype(str)\n",
    "    y_pred_all = df[\"hallucinated\"].astype(str)\n",
    "\n",
    "    metrics[\"overall\"] = {\n",
    "        \"precision\": precision_score(y_true_all, y_pred_all, pos_label=\"y\", zero_division=0),\n",
    "        \"recall\": recall_score(y_true_all, y_pred_all, pos_label=\"y\", zero_division=0),\n",
    "        \"accuracy\": accuracy_score(y_true_all, y_pred_all),\n",
    "        \"support\": len(df)\n",
    "    }\n",
    "\n",
    "    return pd.DataFrame(metrics).T\n"
   ]
  },
