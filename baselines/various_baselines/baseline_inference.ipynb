   "source": [
    "\n",
    "def run_nli_baseline(data, batch_size=8, device=\"cuda\"):\n",
    "    hallucinated_flags = []\n",
    "\n",
    "    for _, row in tqdm(data.iterrows(), total=len(data)):\n",
    "        evidence = row[\"pdf_text\"]\n",
    "        hypothesis = row[\"output_text\"]\n",
    "\n",
    "        chunks = list(chunk_text(evidence, chunk_size=60)) or [\"\"]\n",
    "\n",
    "        chunk_preds = []\n",
    "        for i in range(0, len(chunks), batch_size):\n",
    "            batch_chunks = chunks[i:i+batch_size]\n",
    "            premises = batch_chunks\n",
    "            hyps = [hypothesis] * len(batch_chunks)\n",
    "\n",
    "            encoding = tokenizer_nli(\n",
    "                premises, hyps,\n",
    "                padding=True, truncation=True,\n",
    "                return_tensors=\"pt\"\n",
    "            ).to(device)\n",
    "\n",
    "            with torch.no_grad():\n",
    "                outputs = model_nli(**encoding)   # works with DataParallel\n",
    "                logits = outputs.logits\n",
    "                preds = torch.argmax(logits, dim=1).cpu().tolist()\n",
    "\n",
    "            chunk_preds.extend(preds)\n",
    "\n",
    "            if device == \"cuda\":\n",
    "                torch.cuda.empty_cache()\n",
    "\n",
    "        flag = \"y\" if 2 in chunk_preds else \"n\"\n",
    "        hallucinated_flags.append(flag)\n",
    "\n",
    "    data[\"label\"] = hallucinated_flags\n",
    "    return data\n",
    "\n",
    "\n",
    "\n",
    "def compute_metrics_sklearn(df):\n",
    "    \"\"\"\n",
    "    Compute precision, recall, accuracy per language and overall\n",
    "    using 'nli_hallucinated' vs 'factual_mistake'\n",
    "    \"\"\"\n",
    "    if \"language\" not in df.columns:\n",
    "        df[\"language\"] = df[\"index\"].str[:2]\n",
    "    \n",
    "    metrics = {}\n",
    "    languages = df[\"language\"].unique()\n",
    "\n",
    "    for lang in languages:\n",
    "        sub = df[df[\"language\"] == lang]\n",
    "        y_true = (sub[\"factual_mistake\"] == \"y\").astype(int)\n",
    "        y_pred = (sub[\"label\"] == \"y\").astype(int)\n",
    "\n",
    "        precision = precision_score(y_true, y_pred, zero_division=0)\n",
    "        recall = recall_score(y_true, y_pred, zero_division=0)\n",
    "        accuracy = accuracy_score(y_true, y_pred)\n",
    "\n",
    "        metrics[lang] = {\n",
    "            \"precision\": precision,\n",
    "            \"recall\": recall,\n",
    "            \"accuracy\": accuracy,\n",
    "            \"support\": len(sub)\n",
    "        }\n",
    "\n",
    "    # overall\n",
    "    y_true_all = (df[\"factual_mistake\"] == \"y\").astype(int)\n",
    "    y_pred_all = (df[\"label\"] == \"y\").astype(int)\n",
    "\n",
    "    metrics[\"overall\"] = {\n",
    "        \"precision\": precision_score(y_true_all, y_pred_all, zero_division=0),\n",
    "        \"recall\": recall_score(y_true_all, y_pred_all, zero_division=0),\n",
    "        \"accuracy\": accuracy_score(y_true_all, y_pred_all),\n",
    "        \"support\": len(df)\n",
    "    }\n",
    "\n",
    "    return metrics\n",
    "\n",
    "# data = run_nli_baseline(data, batch_size=128, device=device)  \n",
    "\n",
    "\n"
   ]
