    "import re\n",
    "def detect_hallucination(fava_output: str) -> str:\n",
    "    \"\"\"Return 'y' if hallucination (<delete> tags) present, else 'n'.\"\"\"\n",
    "    if re.search(r\"<delete>.*?</delete>\", fava_output, flags=re.DOTALL):\n",
    "        return \"y\"\n",
    "    return \"n\""
   ]
  },
