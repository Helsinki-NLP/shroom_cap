    "import torch\n",
    "from transformers import AutoTokenizer, AutoModelForSequenceClassification\n",
    "\n",
    "# Pick your model\n",
    "model_name = \"MoritzLaurer/mDeBERTa-v3-base-xnli-multilingual-nli-2mil7\"\n",
    "\n",
    "# Load tokenizer + model\n",
    "tokenizer_nli = AutoTokenizer.from_pretrained(model_name)\n",
    "model_nli = AutoModelForSequenceClassification.from_pretrained(model_name)\n",
    "\n",
    "# If multiple GPUs available, wrap with DataParallel\n",
    "if torch.cuda.device_count() > 1:\n",
    "    print(f\"Using {torch.cuda.device_count()} GPUs with DataParallel\")\n",
    "    model_nli = torch.nn.DataParallel(model_nli)\n",
    "\n",
    "device = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
    "model_nli = model_nli.to(device)\n",
    "model_nli.eval()"
   ]
